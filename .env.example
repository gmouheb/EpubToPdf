# Environment example for EPUB-to-PDF converter
# Leave blank to use defaults

UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
MAX_FILE_SIZE_BYTES=104857600
CONVERSION_TIMEOUT_SECONDS=300
CLEANUP_INTERVAL_MINUTES=10
JOB_RETENTION_MINUTES=60
MAX_CONCURRENT_CONVERSIONS=3
IP_CONVERSION_LIMIT_MAX_FILES=3
IP_CONVERSION_LIMIT_WINDOW_MINUTES=30
# Optional: use seconds instead of minutes, useful for local testing
# IP_CONVERSION_LIMIT_WINDOW_SECONDS=1800
POST_DOWNLOAD_CLEANUP_SECONDS=8
# Optional: set this if ebook-convert is not on PATH
# CALIBRE_BINARY=/usr/bin/ebook-convert
